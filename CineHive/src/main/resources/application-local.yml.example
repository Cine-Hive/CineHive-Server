# =================================================================================
# CineHive 로컬 개발 환경 전용 민감 정보 설정 파일 (템플릿)
# =================================================================================
#
# 이 파일의 목적:
#    - 로컬에서 개발할 때 필요한 개인 API 키나 비밀 키를 관리합니다.
#    - 민감 정보를 Git 저장소에 직접 올리지 않기 위해 사용됩니다.
#
# 사용 방법:
#    1. 이 파일의 이름(application-local.yml.example)을 "application-local.yml"로 복사/변경합니다.
#    2. 아래에 있는 각 항목의 플레이스홀더("...")를 실제 값으로 교체합니다.
#    3. application-local.yml 파일은 .gitignore에 의해 Git 추적에서 제외되므로,
#       안전하게 개인 키를 관리할 수 있습니다.
#
# =================================================================================

app:
  jwt:
    # ---------------------------------------------------------------------------------
    # JWT Secret Key 생성 가이드 (HS512 알고리즘 기준)
    # ---------------------------------------------------------------------------------
    # - JWT 토큰을 서명하고 검증하는 데 사용되는 매우 중요한 비밀 키입니다.
    # - 아래 명령어 중 하나를 터미널에서 실행하여, 암호학적으로 안전한 무작위 문자열을 생성하세요.
    #
    #   (1) OpenSSL 사용 (권장):
    #   openssl rand -base64 64
    #
    #   (2) macOS/Linux의 내장 기능 사용:
    #   head -c 64 /dev/urandom | base64
    # ---------------------------------------------------------------------------------
    secret-key: "여기에_위_명령어로_생성한_JWT_시크릿_키를_붙여넣으세요"

  tmdb:
    # ---------------------------------------------------------------------------------
    # TMDB API Key 발급 가이드 (v3 auth)
    # ---------------------------------------------------------------------------------
    # - 영화/TV/인물 정보를 가져오기 위해 필요한 개인 API 키입니다.
    #
    #   1. TMDB 사이트 접속: https://www.themoviedb.org
    #   2. 회원가입 및 로그인
    #   3. 우측 상단 프로필 아이콘 > 설정 > 좌측 메뉴의 'API' 클릭
    #      (또는 직접 접속: https://www.themoviedb.org/settings/api)
    #   4. 'API 키 요청' 섹션에서 '개발자' 유형으로 신청 및 승인
    #   5. 발급된 "API Key (v3 auth)" 값을 복사하여 아래에 붙여넣으세요.
    # ---------------------------------------------------------------------------------
    api-key: "여기에_TMDB_사이트에서_발급받은_API_키를_붙여넣으세요"
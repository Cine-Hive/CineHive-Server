# 1) 빌드 스테이지: Gradle Wrapper로 fat-jar 생성
FROM openjdk:17-jdk-slim AS builder
WORKDIR /home/gradle/project

# 1-1. Wrapper 스크립트와 설정, JAR 복사
COPY gradlew gradlew.bat settings.gradle build.gradle ./
COPY gradle/wrapper/ gradle/wrapper/

# 1-2. 실행 권한 부여
RUN chmod +x gradlew

# 1-3. 의존성만 먼저 내려받아 캐시 활용 (매우 좋은 최적화입니다)
RUN ./gradlew dependencies --no-daemon --quiet

# 1-4. 전체 소스 복사 후 Boot JAR 생성
COPY . .
RUN ./gradlew bootJar --no-daemon --quiet

# 2) 런타임 스테이지: 최소 JRE만 포함
FROM openjdk:17-jdk-slim
WORKDIR /app

# 2-1. 빌드 스테이지에서 생성된 JAR 파일만 복사
COPY --from=builder /home/gradle/project/build/libs/*.jar app.jar

EXPOSE 8081
ENTRYPOINT ["java", "-jar", "app.jar"]
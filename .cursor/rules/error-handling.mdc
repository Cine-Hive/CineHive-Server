# ErrorResponse JSON 표준
{
  "code": "MOVIE_NOT_FOUND",
  "message": "해당 영화가 없습니다",
  "details": null
}

- `code`는 UPPER_SNAKE_CASE
- `message`는 한국어
- `details`는 선택 항목

# ErrorCode enum 설계
- 도메인별 enum 파일에 정의 (예: `MovieErrorCode`)
- 형식  
  CODE("CODE", HttpStatus, "메시지")

# 예외 계층
- `BusinessException` extends `RuntimeException` (생성자에 `ErrorCode` 전달)
- `GlobalExceptionHandler` (`@RestControllerAdvice`)에서  
  - `BusinessException` 및 Validation 예외 처리  
  - `ErrorCode`의 `HttpStatus`로 `ResponseEntity` 생성  
  - `MethodArgumentNotValidException` → `INVALID_INPUT_VALUE` 코드 변환

# 예시 코드
public enum MovieErrorCode implements ErrorCode {
    MOVIE_NOT_FOUND("MOVIE_NOT_FOUND", HttpStatus.NOT_FOUND, "해당 영화가 없습니다");
}

@Getter
public class BusinessException extends RuntimeException {
    private final ErrorCode errorCode;

    public BusinessException(ErrorCode errorCode) {
        super(errorCode.getMessage());
        this.errorCode = errorCode;
    }
}
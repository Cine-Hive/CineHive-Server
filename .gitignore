# =========================================
# Build & Dependencies
# - 빌드 결과물 및 로컬 의존성 폴더
# =========================================
build/
bin/
out/
.gradle/
target/
.mvn/
node_modules/

# Gradle Wrapper는 버전 관리에 포함해야 하므로 예외 처리
!gradle/wrapper/gradle-wrapper.jar

# =========================================
# IDEs & Editors
# - 각 개발 환경에서 자동 생성되는 설정 파일
# =========================================
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Eclipse / STS
.settings/
.classpath
.project
.factorypath
.apt_generated
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
.ionide
*.vsix

# =========================================
# Local Configuration & Secrets
# - 로컬 환경 전용 설정 및 민감 정보 파일
# =========================================
.env
.env.*
application-local.yml

# =========================================
# OS Generated Files
# - 운영체제가 자동으로 생성하는 파일
# =========================================
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
Icon
Thumbs.db
.Trashes
.TemporaryItems
Network Trash Folder
.com.apple.timemachine.donotpresent

# =========================================
# Log Files
# - 애플리케이션 실행 로그
# =========================================
logs/
*.log
spring.log

# =========================================
# Build Artifacts & Other Files
# - 컴파일된 클래스, JAR 파일, 임시 파일, DB 덤프 등
# =========================================
*.class
*.jar
*.war
*.ear
*.swp
*.swo
*.bak
*.tmp
*.sql
.cursorrules